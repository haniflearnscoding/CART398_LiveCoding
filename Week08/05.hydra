solid(0.05,0.0,0.1)
  .layer(osc(62.8,0).thresh(0.65).luma()
    .modulate(osc(8,1).rotate(1),0.03)
    .color(0.8,0.2,1.0))
  .layer(osc(31.4,0).thresh(0.7).luma()
    .modulate(noise(3,0.1),0.08)
    .color(0,1,0.8))
  .pixelate(()=>Math.sin(time)*40+60, ()=>Math.sin(time*1.3)*40+60)
  .scrollX(()=>Math.sin(time*0.5)*0.01)
  .out()
